{
  "name": "@jweston/trigger",
  "version": "0.21.6",
  "description": "⚡Data-oriented state management for React",
  "keywords": [
    "react",
    "state",
    "state management",
    "trigger",
    "data oriented",
    "typescript"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "author": "Josh Weston",
  "license": "MIT",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "test": "jest --transformIgnorePatterns 'node_modules/(?!node-fetch)/' --rootDir=./tests --watch index.test.ts",
    "test-nested": "jest --transformIgnorePatterns 'node_modules/(?!node-fetch)/' --rootDir=./tests --watch nested.test.ts",
    "test-silent": "jest --silent --transformIgnorePatterns 'node_modules/(?!node-fetch)/' --rootDir=./tests --watch index.test.ts",
    "test-build": "jest --silent --rootDir=./tests",
    "test-use-one": "jest --transformIgnorePatterns 'node_modules/(?!node-fetch)/' --rootDir=./tests --watch useOne.test.ts",
    "test-update-one": "jest --transformIgnorePatterns 'node_modules/(?!node-fetch)/' --rootDir=./tests --watch updateOne.test.ts",
    "build-watch": "tsc -w",
    "build": "tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run test-build && npm run format-and-lint",
    "preversion": "npm run test-build && npm run format-and-lint",
    "version": "npm run build && git add --force -A lib",
    "postversion": "git push && git push --tags",
    "format": "prettier --config .prettierrc --write \"src/**/*.ts\"",
    "lint": "eslint .",
    "format-and-lint": "npm run lint && npm run format",
    "api-server": "json-server ./tests/data.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/josh-weston/trigger.git"
  },
  "bugs": "https://github.com/josh-weston/trigger/issues",
  "homepage": "https://trigger.joshweston.ca",
  "files": [
    "lib/**/*"
  ],
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@testing-library/react": "16.3.2",
    "@types/jest": "30.0.0",
    "@types/react": "19.2.9",
    "eslint": "9.39.2",
    "eslint-plugin-react": "7.37.5",
    "globals": "17.1.0",
    "isomorphic-fetch": "3.0.0",
    "jest": "30.2.0",
    "jest-environment-jsdom": "30.2.0",
    "jiti": "2.6.1",
    "json-server": "0.17.4",
    "prettier": "3.8.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "ts-jest": "29.4.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.53.1"
  }
}
